# Application
APP_NAME=onramp
DEBUG=false
HOST=0.0.0.0
PORT=8000

SIGNATURE_VALID_SECONDS=300

SECRET_KEY=change-me-in-production-min-32-bytes!!
AUTHENTICATION_DISABLED=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onramp

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ORDER_TASKS_TOPIC=executor.public.order_tasks
KAFKA_CONSUMER_GROUP=onramp-order-tasks-consumer
ENABLE_ORDER_TASKS_CDC=true